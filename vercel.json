{
  "name": "finanzas-con-ren",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @workspace/comparador-prestamos build",
  "outputDirectory": "artifacts/comparador-prestamos/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  }
}
